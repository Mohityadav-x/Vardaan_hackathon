<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="@drawable/pink">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Hello, User"
            android:textSize="28sp"
            android:textColor="#680732"
            android:fontFamily="@font/poppins_bold"
            android:layout_margin="20dp"
            android:layout_marginBottom="16dp"/>

        <!-- Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            app:cardCornerRadius="30dp"
            android:layout_marginTop="30dp"
            app:cardElevation="10dp"
            android:layout_margin="20dp">
<ImageView
    android:layout_width="32dp"
    android:layout_height="32dp"
    android:background="@drawable/img_1"

    android:layout_marginLeft="20dp"
    android:layout_marginTop="46dp">

</ImageView>
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Heart Rate: 78 bpm"
                android:gravity="center"
                android:fontFamily="@font/poppins_bold"
                android:textColor="#680732"
                android:layout_marginTop="40dp"
                android:layout_marginLeft="60dp"
                android:textSize="25sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Card 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="10dp"
            android:layout_margin="20dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="10dp"
            android:padding="12dp">

            <ImageView
                android:layout_width="33dp"
                android:layout_height="33dp"
                android:background="@drawable/spo2"
                android:layout_marginLeft="20dp"

                android:layout_marginTop="46dp">

            </ImageView>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="SpO2: 98%"
                android:layout_marginTop="42dp"
                android:textColor="#680732"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginLeft="60dp"
                android:textSize="25dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Card 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="30dp"
            android:layout_margin="20dp"
            app:cardElevation="10dp"
            android:padding="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/baseline_calendar_month_24"

                android:layout_marginLeft="17dp"
                android:layout_marginTop="43dp">

            </ImageView>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Expected Period Date: 25 April"
                android:layout_marginTop="25dp"
                android:layout_marginLeft="60dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="#680732"
                android:textSize="25sp"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="30dp"
            android:layout_margin="20dp"
            app:cardElevation="10dp"
            android:padding="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/pcos"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="40dp">

            </ImageView>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="PCOS RISK: Medium"
                android:layout_marginTop="40dp"
                android:textColor="#680732"
                android:layout_marginLeft="60dp"
                android:fontFamily="@font/poppins_bold"
                android:textSize="25sp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>