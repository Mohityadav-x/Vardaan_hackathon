<?xml version="1.0" encoding="utf-8"?>


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/pink"
    android:padding="16dp"
    android:orientation="vertical">

    <TextView
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="Symptom Checker"
        android:textSize="28sp"
        android:textColor="#680732"
        android:fontFamily="@font/poppins_bold"
        android:layout_margin="20dp"
        android:layout_marginBottom="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="7dp"
       android:layout_marginHorizontal="20dp">




        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">


            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="25dp"
                android:scaleX="1.4"
                android:scaleY="1.4"
                android:id="@+id/acne"
                android:layout_marginTop="30dp">

            </CheckBox>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acne"
                android:textSize="25dp"
                android:layout_marginTop="33dp"
                android:fontFamily="@font/poppins_regular"
                >

            </TextView>
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="70dp"
                android:layout_marginLeft="25dp"
                android:scaleX="1.4"
                android:id="@+id/moodswings"
                android:scaleY="1.4">

            </CheckBox>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood Swings"
                android:fontFamily="@font/poppins_regular"
                android:textSize="25dp"
                android:layout_marginTop="73dp">

            </TextView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">


            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginLeft="25dp"
                android:scaleX="1.4"
                android:scaleY="1.4"
                android:id="@+id/irregularperoids"
                android:layout_marginTop="112dp">

            </CheckBox>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Irregular Peroids"
                android:textSize="25dp"
                android:layout_marginTop="115dp"
                android:fontFamily="@font/poppins_regular"
                >

            </TextView>
        </LinearLayout>

        <Button
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:text="Check Risk"
            android:layout_marginTop="175dp"
            android:layout_marginHorizontal="75dp"
            android:textSize="23dp"
            android:id="@+id/btncheck"
            android:backgroundTint="#ff91af">

        </Button>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="30dp">
<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk :"
            android:textSize="28dp"
            android:layout_marginTop="20dp"
            android:textColor="#680732"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginLeft="25dp">
        </TextView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medium"
        android:textSize="28dp"
        android:layout_marginTop="20dp"
        android:textColor="#680732"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginLeft="10dp"
        android:id="@+id/risk"/>



</LinearLayout>

    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black">
    </View>


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommended for you"
        android:textColor="#680732"
        android:layout_marginLeft="75dp"
        android:fontFamily="@font/poppins_bold"
        android:textSize="20dp">

    </TextView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardCornerRadius="30dp"
        android:layout_marginHorizontal="20dp"
        android:id="@+id/diet"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Healthy Diet "
            android:textSize="20dp"
            android:layout_marginTop="25dp"
            android:textColor="#680732"
            android:layout_marginLeft="40dp"
            android:fontFamily="@font/poppins_regular">

        </TextView>





    </com.google.android.material.card.MaterialCardView>



    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardCornerRadius="30dp"
        android:layout_marginTop="10dp"
       android:layout_marginHorizontal="20dp"
        android:id="@+id/yoga"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOGA"
            android:textSize="20dp"
            android:layout_marginTop="25dp"
            android:layout_marginLeft="40dp"
            android:textColor="#680732"
            android:fontFamily="@font/poppins_regular">

        </TextView>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>