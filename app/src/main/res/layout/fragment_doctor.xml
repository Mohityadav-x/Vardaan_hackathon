<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="1"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="@drawable/pink">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <!-- Title -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Doctor consultant"
            android:textSize="28sp"
            android:textColor="#680732"
            android:fontFamily="@font/poppins_bold"
            android:layout_margin="20dp"
            android:layout_marginBottom="16dp"/>

        <!-- Card 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            app:cardCornerRadius="30dp"
            android:layout_marginTop="30dp"
            app:cardElevation="10dp"
            android:layout_margin="20dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="25dp"
                android:layout_marginLeft="15dp"
                android:background="@drawable/img">

            </com.google.android.material.imageview.ShapeableImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr.Rahul"
                    android:textSize="25dp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#680732"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="15dp">

                </TextView>


            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fees:4000"
                android:layout_marginLeft="130dp"
                android:textSize="18dp"
                android:layout_marginTop="65dp"
                android:fontFamily="@font/poppins_regular">

            </TextView>

                <RatingBar
                    android:layout_width="250dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="63dp"
                    android:progressTint="#E452C7"
                    android:numStars="5"
                    android:rating="4"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:fontFamily="@font/poppins_regular">

            </RatingBar>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            app:cardCornerRadius="30dp"
            android:layout_marginTop="30dp"
            app:cardElevation="10dp"
            android:layout_margin="20dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginLeft="15dp"
                    android:background="@drawable/img">

                </com.google.android.material.imageview.ShapeableImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr.Sharma"
                    android:textSize="25dp"
                    android:textColor="#680732"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="15dp">

                </TextView>


            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fees:2000"
                    android:layout_marginLeft="130dp"
                    android:textSize="18dp"
                    android:layout_marginTop="65dp"
                    android:fontFamily="@font/poppins_regular">

                </TextView>

                <RatingBar
                    android:layout_width="250dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="63dp"
                    android:progressTint="#E452C7"
                    android:numStars="5"
                    android:rating="3"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:fontFamily="@font/poppins_regular">

                </RatingBar>
            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            app:cardCornerRadius="30dp"
            android:layout_marginTop="30dp"
            app:cardElevation="10dp"
            android:layout_margin="20dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginLeft="15dp"
                    android:background="@drawable/img">

                </com.google.android.material.imageview.ShapeableImageView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr.Mishra"
                    android:textSize="25dp"
                    android:textColor="#680732"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="15dp">

                </TextView>


            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fees:6000"
                    android:layout_marginLeft="130dp"
                    android:textSize="18dp"
                    android:layout_marginTop="65dp"
                    android:fontFamily="@font/poppins_regular">

                </TextView>

                <RatingBar
                    android:layout_width="250dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="63dp"
                    android:progressTint="#E452C7"
                    android:numStars="5"
                    android:rating="5"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:fontFamily="@font/poppins_regular">

                </RatingBar>
            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="10dp"
            android:padding="12dp"
            app:cardCornerRadius="30dp"
            android:layout_marginTop="30dp"
            app:cardElevation="10dp"
